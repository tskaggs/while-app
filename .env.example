# Public URL, used for OG Image when running nuxt generate
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Set to true to use mock data without database (UI-only dev)
NUXT_PUBLIC_MOCK_MODE=false

# Shared PostgreSQL (same database as ultra-a control plane)
# ultra-a Docker maps Postgres to host port 5433 to avoid conflicting with a local Postgres on 5432.
DATABASE_URL=postgresql://while:while@localhost:5433/while

# ultra-a FastAPI control plane
WHILE_API_URL=http://localhost:8000

# Better-Auth
BETTER_AUTH_SECRET=dev-secret-change-me-in-production-32chars
BETTER_AUTH_URL=http://localhost:3000
