# Hoist markdown pipeline deps so Vite optimizeDeps can resolve them (@nuxtjs/mdc)
public-hoist-pattern[]=*remark*
public-hoist-pattern[]=*rehype*
public-hoist-pattern[]=unified
public-hoist-pattern[]=unist-util-*
public-hoist-pattern[]=parse5
public-hoist-pattern[]=debug
public-hoist-pattern[]=extend
