generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Better-Auth (generated via npx auth@latest generate) ---

model User {
  id            String       @id
  name          String
  email         String
  emailVerified Boolean      @default(false)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  sessions      Session[]
  accounts      Account[]
  members       Member[]
  invitations   Invitation[]

  @@unique([email])
  @@map("user")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id          String       @id
  name        String
  slug        String
  logo        String?
  createdAt   DateTime
  metadata    String?
  members     Member[]
  invitations Invitation[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

// --- Machine plane (shared with ultra-a control plane) ---

model MachineOrganization {
  id        String   @id @db.Uuid
  name      String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  apiKeys              ApiKey[]
  sandboxSettings      SandboxSettings?
  sandboxProfile       OrgSandboxProfile?
  dashboardConnections DashboardConnection[]
  connectionRequests   ConnectionRequest[]
  orgOnboarding        OrgOnboarding?
  machineApiTokens     MachineApiToken[]
  processedMessages    ProcessedMessage[]
  integrationLogs      IntegrationLog[]
  tunnelLogs           TunnelLog[]
  tunnelIncidents      TunnelIncident[]
  dailyMetricRollups   DailyMetricRollup[]

  @@map("organizations")
}

model ApiKey {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  hashedKey   String   @unique @map("hashed_key") @db.Char(64)
  keyPrefix   String   @map("key_prefix") @db.VarChar(12)
  environment String   @db.VarChar(10)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz

  organization MachineOrganization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model SandboxSettings {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId               String   @unique @map("org_id") @db.Uuid
  webhookUrl          String?  @map("webhook_url")
  webhookSecret       String?  @map("webhook_secret")
  cronEnabled         Boolean  @default(true) @map("cron_enabled")
  cronIntervalSeconds Int      @default(300) @map("cron_interval_seconds")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization MachineOrganization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("sandbox_settings")
}

// --- Dashboard app extensions ---

model DashboardConnection {
  id                   String    @id
  orgId                String    @map("org_id") @db.Uuid
  name                 String
  connectionType       String    @map("connection_type")
  environment          String
  pairedConnectionId   String?   @map("paired_connection_id")
  isHidden             Boolean   @default(false) @map("is_hidden")
  isDeletable          Boolean   @default(true) @map("is_deletable")
  sidecarId            String?   @map("sidecar_id")
  tunnelStatus         String    @default("pending") @map("tunnel_status")
  wireguardPublicKey   String?   @map("wireguard_public_key")
  ehrEndpoint          String?   @map("ehr_endpoint")
  ehrVendor            String?   @map("ehr_vendor")
  lastSyncAt           DateTime? @map("last_sync_at") @db.Timestamptz
  region               String    @default("control-plane")
  messagesProcessed24h Int       @default(0) @map("messages_processed_24h")
  webhookUrl           String?   @map("webhook_url")
  webhookSecret        String?   @map("webhook_secret")
  provisioningStatus   String    @default("active") @map("provisioning_status")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz

  organization    MachineOrganization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fieldMappings   ConnectionFieldMapping[]
  requiredData    ConnectionRequiredData?
  wireguardPeer    ConnectionWireguardPeer?
  provisioningJobs ProvisioningJob[]

  @@map("dashboard_connections")
}

model OrgSandboxProfile {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                  String   @unique @map("org_id") @db.Uuid
  ehrVendor              String   @default("Other") @map("ehr_vendor")
  dataFormat             String   @default("fhir") @map("data_format")
  resourceTypes          Json     @default("[\"Patient\"]") @map("resource_types")
  suggestedFieldsVersion String   @default("1") @map("suggested_fields_version")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization MachineOrganization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_sandbox_profiles")
}

model ConnectionFieldMapping {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId          String   @map("org_id") @db.Uuid
  connectionId   String   @map("connection_id")
  sourcePath     String   @map("source_path")
  targetFhirPath String   @map("target_fhir_path")
  status         String   @default("suggested")
  isRequired     Boolean  @default(false) @map("is_required")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  connection DashboardConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, sourcePath])
  @@index([orgId, connectionId])
  @@map("connection_field_mappings")
}

model ConnectionRequiredData {
  connectionId String    @id @map("connection_id")
  orgId        String    @map("org_id") @db.Uuid
  ehrEndpoint  String?   @map("ehr_endpoint")
  ehrVendor    String?   @map("ehr_vendor")
  customFields Json      @default("{}") @map("custom_fields")
  completedAt  DateTime? @map("completed_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  connection DashboardConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@map("connection_required_data")
}

model ConnectionRequest {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  partnerName     String   @map("partner_name")
  ehrVendor       String   @map("ehr_vendor")
  contactEmail    String   @map("contact_email")
  targetGoLive    String   @map("target_go_live")
  scope           String
  resourceTypes   Json     @default("[]") @map("resource_types")
  dataFormat      String   @map("data_format")
  environment     String
  estimatedVolume String   @map("estimated_volume")
  notes           String?
  status          String   @default("pending")
  connectionId    String?  @map("connection_id")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization MachineOrganization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@map("connection_requests")
}

model ConnectionWireguardPeer {
  connectionId  String   @id @map("connection_id")
  orgId         String   @map("org_id") @db.Uuid
  environment   String   @default("sandbox")
  publicKey     String   @map("public_key")
  privateKeyRef String?  @map("private_key_ref")
  endpoint      String?
  listenPort    Int?     @map("listen_port")
  allowedIps    String   @default("10.8.0.0/24") @map("allowed_ips")
  peerConfig    Json     @default("{}") @map("peer_config")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  connection DashboardConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@map("connection_wireguard_peers")
}

model ProvisioningJob {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String    @map("org_id") @db.Uuid
  connectionId    String    @map("connection_id")
  environment     String    @default("sandbox")
  jobType         String    @map("job_type")
  status          String    @default("queued")
  stage           String    @default("queued")
  vmId            String?   @map("vm_id")
  orchestratorVmId String?  @map("orchestrator_vm_id")
  progressPercent Int       @default(0) @map("progress_percent")
  errorMessage    String?   @map("error_message")
  startedAt       DateTime? @map("started_at") @db.Timestamptz
  completedAt     DateTime? @map("completed_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  connection DashboardConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, environment])
  @@index([orgId, status])
  @@index([status, stage])
  @@map("provisioning_jobs")
}

model MachineApiToken {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  name        String
  tokenHash   String    @unique @map("token_hash") @db.Char(64)
  tokenPrefix String    @map("token_prefix") @db.VarChar(12)
  scopes      String[]  @default([])
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  organization MachineOrganization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("machine_api_tokens")
}

model ProcessedMessage {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  connectionId  String   @map("connection_id")
  partnerName   String   @map("partner_name")
  environment   String
  timestamp     DateTime @db.Timestamptz
  direction     String
  format        String
  messageType   String   @map("message_type")
  resourceType  String?  @map("resource_type")
  status        String
  summary       String
  correlationId String?  @map("correlation_id")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization MachineOrganization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, environment, timestamp])
  @@index([orgId, connectionId, timestamp])
  @@map("processed_messages")
}

model IntegrationLog {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId             String   @map("org_id") @db.Uuid
  connectionId      String   @map("connection_id")
  partnerName       String   @map("partner_name")
  environment       String
  timestamp         DateTime @db.Timestamptz
  severity          String
  category          String
  message           String
  anonymizedMessage String   @map("anonymized_message")
  resourceType      String?  @map("resource_type")
  eventType         String?  @map("event_type")
  hl7MessageType    String?  @map("hl7_message_type")
  correlationId     String?  @map("correlation_id")
  durationMs        Int?     @map("duration_ms")
  statusCode        Int?     @map("status_code")
  actor             String?
  ipAddress         String?  @map("ip_address")
  source            String?
  details           String?
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization MachineOrganization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, environment, timestamp])
  @@index([orgId, category, timestamp])
  @@map("integration_logs")
}

model TunnelLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  connectionId String   @map("connection_id")
  partnerName  String   @map("partner_name")
  environment  String
  timestamp    DateTime @db.Timestamptz
  severity     String
  eventType    String   @map("event_type")
  message      String
  incidentId   String?  @map("incident_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization MachineOrganization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, environment, timestamp])
  @@index([orgId, connectionId, timestamp])
  @@map("tunnel_logs")
}

model TunnelIncident {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String    @map("org_id") @db.Uuid
  connectionId  String    @map("connection_id")
  partnerName   String    @map("partner_name")
  environment   String
  title         String
  summary       String
  severity      String
  status        String
  startedAt     DateTime  @map("started_at") @db.Timestamptz
  resolvedAt    DateTime? @map("resolved_at") @db.Timestamptz
  relatedLogIds String[]  @default([]) @map("related_log_ids")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  organization MachineOrganization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, environment])
  @@map("tunnel_incidents")
}

model DailyMetricRollup {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  connectionId  String   @map("connection_id")
  environment   String
  date          DateTime @db.Date
  messageCount  Int      @default(0) @map("message_count")
  fhirResources Int      @default(0) @map("fhir_resources")
  uptimePct     Float    @default(100) @map("uptime_pct")
  tunnelEvents  Int      @default(0) @map("tunnel_events")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization MachineOrganization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, connectionId, environment, date])
  @@index([orgId, environment, date])
  @@map("daily_metric_rollups")
}

model OrgOnboarding {
  orgId              String    @id @map("org_id") @db.Uuid
  completedAt        DateTime? @map("completed_at") @db.Timestamptz
  apiKeyShownAt      DateTime? @map("api_key_shown_at") @db.Timestamptz
  pendingSandboxKey  String?   @map("pending_sandbox_key")

  organization MachineOrganization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_onboarding")
}
